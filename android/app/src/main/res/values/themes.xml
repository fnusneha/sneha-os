<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark-only app theme. WebView handles the actual page palette; this
         theme only controls the Activity chrome (status/navigation bars
         + default text color before WebView loads). -->
    <style name="Theme.SnehaOS" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/brand_bg</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
        <item name="colorPrimary">@color/brand_mint</item>
        <item name="colorAccent">@color/brand_mint</item>
        <item name="android:colorBackground">@color/brand_bg</item>
        <item name="android:windowBackground">@color/brand_bg</item>
    </style>

    <style name="Theme.SnehaOS.Splash" parent="Theme.SnehaOS">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
